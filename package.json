{
  "name": "fastgpt",
  "version": "4.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "prebuild": "node scripts/generate-robots.js && node scripts/generate-llms.js",
    "build": "next build && node scripts/clean-faq-rsc.js && node scripts/copy-root-index.js",
    "start": "npx serve@latest out",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "prepare": "husky",
    "format-code": "prettier --config \"./.prettierrc.js\" --write \"./**/src/**/*.{ts,tsx,scss}\"",
    "clean-locales": "node scripts/clean-locales.js",
    "convert-images": "node scripts/convert-images.js"
  },
  "dependencies": {
    "@heroui/react": "^2.8.9",
    "@heroui/theme": "^2.4.26",
    "@radix-ui/react-slot": "^1.0.2",
    "autoprefixer": "^10.4.24",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cobe": "^2.0.1",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.0.1",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "20.19.33",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "husky": "^9.1.7",
    "prettier": "^2.8.8",
    "sharp": "^0.33.5",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
